# Python Honeypot specific
python-honeypot/
├── .gitignore          # Proper ignore patterns
├── README.md           # Complete documentation
├── requirements.txt    # Single dependency (paramiko)
├── server.key          # SSH host private key
├── server.key.pub      # SSH host public key
├── ssh_honeypot.py     # Main honeypot script
├── logs/               # Log directory (created when running)
│   ├── auth.log        # Authentication attempts (syslog format)
│   ├── commands.log    # Commands executed in shell
│   ├── connections.log # Connection metadata
│   └── errors.log      # Error traces
└── __pycache__/        # Python bytecode (ignored)